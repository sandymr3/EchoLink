<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EchoLink.ViewModels"
             xmlns:m="using:EchoLink.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
             x:Class="EchoLink.Views.RemoteControlView"
             x:DataType="vm:RemoteControlViewModel"
             Background="Transparent">

    <DockPanel Margin="32,24">

        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Spacing="6" Margin="0,0,0,24">
            <TextBlock Text="Remote Control"
                       FontSize="28" FontWeight="Bold" Foreground="#FFFFFF"/>
            <TextBlock Text="Send commands and control the target device remotely"
                       FontSize="13" Foreground="#B3B3B3"/>
        </StackPanel>

        <!-- Device Selection -->
        <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
            <StackPanel Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="Target Device"
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="#B3B3B3"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="↻ Refresh" Command="{Binding LoadDevicesCommand}"
                            Classes="Nav" Background="Transparent" Foreground="#3273F6" Padding="6,2" FontSize="12"/>
                </Grid>
                <ComboBox ItemsSource="{Binding OnlineDevices}"
                          SelectedItem="{Binding SelectedTarget}"
                          HorizontalAlignment="Stretch"
                          PlaceholderText="Choose a peer to control…">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="m:Device">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{Binding DeviceIcon}" FontSize="16"/>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding IpAddress}" Foreground="#B3B3B3" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <!-- Quick Actions (UniformGrid 3-col) -->
        <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
            <StackPanel Spacing="12">
                <TextBlock Text="Quick Actions"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#B3B3B3"/>
                <UniformGrid Columns="3" >
                    <!-- Lock -->
                    <Button Classes="Primary"
                            Command="{Binding LockScreenCommand}"
                            Margin="0,0,8,0"
                            HorizontalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="🔒" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Lock Screen" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Restart -->
                    <Button Background="#FF9800"
                            Foreground="#121212"
                            CornerRadius="8"
                            Padding="16,14"
                            Margin="4,0"
                            Command="{Binding RestartCommand}"
                            HorizontalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="🔄" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Restart" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Shutdown -->
                    <Button Classes="Danger"
                            Command="{Binding ShutdownCommand}"
                            Margin="8,0,0,0"
                            HorizontalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <TextBlock Text="⏻" FontSize="28" HorizontalAlignment="Center"/>
                            <TextBlock Text="Shutdown" FontSize="12" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top" Classes="Card" Margin="0,0,0,20">
            <StackPanel Spacing="12">
                <TextBlock Text="Live Audio"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#B3B3B3"/>

                <TextBlock Text="{Binding AudioStatus}"
                           FontSize="12"
                           Foreground="#00E5FF"/>

                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0"
                            Classes="Primary"
                            Command="{Binding StartAudioCommand}"
                            Content="Start Audio"
                            IsEnabled="{Binding !IsAudioStreaming}"/>

                    <Button Grid.Column="1"
                            Classes="Danger"
                            Command="{Binding StopAudioCommand}"
                            Content="Stop Audio"
                            IsEnabled="{Binding IsAudioStreaming}"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Trackpad area -->
        <StackPanel DockPanel.Dock="Top" Spacing="8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Trackpad"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#B3B3B3"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TrackpadStatus}"
                           FontSize="12" Foreground="#00E5FF"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Name="TrackpadArea"
                    Background="#1A1A1A"
                    CornerRadius="12"
                    MinHeight="300">
                <TextBlock Text="Move pointer here"
                           FontSize="14" Foreground="#3A3A3A"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </StackPanel>

    </DockPanel>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EchoLink.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="700"
             x:Class="EchoLink.Views.LoginView"
             x:DataType="vm:LoginViewModel"
             Background="#121212">

    <Design.DataContext>
        <vm:LoginViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*">
        <Border Grid.Row="0" Padding="40">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="24"
                        Width="320">

                <!-- Logo -->
                <StackPanel HorizontalAlignment="Center" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                HorizontalAlignment="Center">
                        <Ellipse Width="14" Height="14"
                                 Fill="#00E676"
                                 VerticalAlignment="Center"/>
                        <TextBlock Text="EchoLink"
                                   FontSize="32" FontWeight="Bold"
                                   Foreground="#FFFFFF"/>
                    </StackPanel>
                    <TextBlock Text="Mesh Network"
                               FontSize="13"
                               Foreground="#B3B3B3"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Divider -->
                <Border Height="1" Background="#2D2D2D" Margin="0,8"/>

                <!-- Status text -->
                <TextBlock Text="{Binding StatusText}"
                           FontSize="13"
                           Foreground="#B3B3B3"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"/>

                <!-- Loading spinner -->
                <ProgressBar IsIndeterminate="True"
                             IsVisible="{Binding IsLoading}"
                             Height="3"
                             Foreground="#00E676"
                             Background="#2D2D2D"/>

                <!-- Login button -->
                <Button Command="{Binding LoginWithGoogleCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,14"
                        CornerRadius="8"
                        Background="#00E676"
                        Foreground="#121212"
                        FontSize="15"
                        FontWeight="Bold">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Log In with Google" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Cancel button — only visible while loading -->
                <Button Command="{Binding CancelCommand}"
                        IsVisible="{Binding IsLoading}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Padding="0,10"
                        CornerRadius="8"
                        Background="#2D2D2D"
                        Foreground="#B3B3B3"
                        FontSize="13">
                    <TextBlock Text="Cancel"/>
                </Button>

                <!-- Footer -->
                <TextBlock Text="Connects via Headscale · echo-link.app"
                           FontSize="10"
                           Foreground="#4A4A4A"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
